<?xml version="1.0" encoding="UTF-8"?>
<!--
    Cyberbox SIEM Agent — WiX v4 MSI installer
    ============================================
    Build with:
      wix build packaging/windows/cyberbox-agent.wxs ^
        -d Version=0.1.0 ^
        -d BinaryPath=target/release/cyberbox-agent.exe ^
        -d ConfigPath=apps/cyberbox-agent/agent.example.toml ^
        -d IconPath=web/cyberbox-ui/public/cyberboxlogo.png ^
        -o cyberbox-agent-0.1.0.msi

    Requires: WiX Toolset v4+  (winget install WixToolset.WiX)
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Cyberbox SIEM Agent"
    Manufacturer="Cyberbox Security"
    Version="$(var.Version)"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Cyberbox Agent is already installed."
      AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Branding -->
    <Icon Id="CyberboxIcon" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="CyberboxIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/cyberboxsiem/CyberboxSIEM" />

    <!-- Install directory: C:\Program Files\Cyberbox\Agent\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="CYBERBOXDIR" Name="Cyberbox">
        <Directory Id="INSTALLDIR" Name="Agent" />
      </Directory>
    </StandardDirectory>

    <!-- Data directory: %ProgramData%\Cyberbox\ -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATADIR" Name="Cyberbox" />
    </StandardDirectory>

    <!-- Main component: binary + default config -->
    <ComponentGroup Id="AgentComponents" Directory="INSTALLDIR">
      <Component Id="AgentBinary" Bitness="always64">
        <File Id="AgentExe"
              Source="$(var.BinaryPath)"
              Name="cyberbox-agent.exe"
              KeyPath="yes" />

        <!-- Register as a Windows Service -->
        <ServiceInstall
          Id="CyberboxAgentService"
          Name="CyberboxAgent"
          DisplayName="Cyberbox SIEM Agent"
          Description="Lightweight log-forwarding agent for CyberboxSIEM. Collects Windows Event Logs, Sysmon events, and file integrity data."
          Start="auto"
          Type="ownProcess"
          ErrorControl="normal"
          Arguments="run --config &quot;[DATADIR]agent.toml&quot;" />

        <ServiceControl
          Id="StartCyberboxAgent"
          Name="CyberboxAgent"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>
    </ComponentGroup>

    <!-- Default config file in ProgramData -->
    <ComponentGroup Id="ConfigComponents" Directory="DATADIR">
      <Component Id="DefaultConfig" Bitness="always64">
        <File Id="AgentToml"
              Source="$(var.ConfigPath)"
              Name="agent.toml"
              KeyPath="yes" />
        <!-- NeverOverwrite: don't clobber user edits on upgrade -->
        <Condition>NOT Installed</Condition>
      </Component>
    </ComponentGroup>

    <Feature Id="Complete" Title="Cyberbox Agent" Level="1">
      <ComponentGroupRef Id="AgentComponents" />
      <ComponentGroupRef Id="ConfigComponents" />
    </Feature>

  </Package>
</Wix>
